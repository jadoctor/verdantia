rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Carpeta uploads/ → lectura pública (fotos, PDFs, blogs)
    match /uploads/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
    
    // Carpeta temporal → pública para el Client-Side Upload (el servidor la vacía después)
    match /uploads/temp/{allPaths=**} {
      allow write: if true;
    }
  }
}
